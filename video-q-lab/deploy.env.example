# Local-only deploy secrets — DO NOT COMMIT
#
# 1. Copy this file to .env.deploy (gitignored):
#    cp deploy.env.example .env.deploy
# 2. Set MONGO_URI to your Atlas connection string (use a NEW password if the old one leaked).
# 3. (Optional) Set ALERT_EMAIL to receive CloudWatch alarm notifications.
# 4. Run: ./deploy.sh

MONGO_URI='<your-atlas-connection-string>'

# Optional: email address for CloudWatch alarm SNS notifications.
# ALERT_EMAIL='you@example.com'

# -----------------------------------------------------------------------
# The variables below are automatically injected into App Runner by
# Terraform. You do NOT need to set them for a normal deployment.
# They are documented here for running the dashboard outside App Runner
# (e.g. docker run locally against the real AWS resources).
# -----------------------------------------------------------------------
# SFN_ARN='<terraform output step_function_arn>'
# GCP_SFN_ARN='<terraform output gcp_step_function_arn>'
# BATCH_JOB_QUEUE='<terraform output batch_job_queue_name>'
# AWS_REGION='us-east-1'
