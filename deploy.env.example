# Local-only deploy secrets — DO NOT COMMIT
#
# 1. Copy this file to .env.deploy (gitignored):
#    cp deploy.env.example .env.deploy
# 2. Set MONGO_URI to your Atlas connection string (use a NEW password if the old one leaked).
# 3. Optional: set GCP_CREDENTIALS_SECRET_ARN to your Secrets Manager secret ARN (plain string).
#    If set, ./deploy.sh passes it to Terraform as gcp_credentials_secret_arn and skips creating a new GCP key.
# 4. Run: ./deploy.sh

MONGO_URI='mongodb+srv://USER:PASSWORD@cluster.mongodb.net/master?retryWrites=true&w=majority'
# export GCP_CREDENTIALS_SECRET_ARN='arn:aws:secretsmanager:REGION:ACCOUNT:secret:name-SUFFIX'

# --- Mongo (optional overrides; defaults: master, showcache, episode, episode_vtt) ---
# export MONGO_DATABASE='master'
# export MONGO_SHOWCACHE_COLLECTION='showcache'
# export MONGO_EPISODE_COLLECTION='episode'
# export MONGO_VTT_COLLECTION='episode_vtt'

# --- Thumbnail VTT / WebP sprites (vtt-worker + dashboard) — separate from transcoder GCS buckets ---
# Same MONGO_URI as above for the worker unless you set VTT_MONGO_URI.
# Sprites bucket only (not chai-q-transcoder-input/output).
# export VTT_GCS_BUCKET='media-cdn-poc-466009-sprites'
# export VTT_GCS_PREFIX='output/webp/'
# Local/docker only: path to SA JSON for sprite uploads (do not commit the file).
# export VTT_GOOGLE_APPLICATION_CREDENTIALS='/absolute/path/to/vtt-gcp-sa.json'
# After deploying vtt-worker to Cloud Run — base URL only (dashboard appends /process).
# export VTT_WORKER_URL='https://vtt-worker-xxxxx.run.app'
# Optional alias for the same URL:
# export VTT_SERVICE_URL='https://vtt-worker-xxxxx.run.app'
# Optional shared secret (set same value on worker and dashboard).
# export VTT_WORKER_SECRET='long-random-string'

# Legacy fallbacks (still supported by vtt-worker): GCS_BUCKET, GCS_PREFIX
# export GCS_BUCKET='media-cdn-poc-466009-sprites'
# export GCS_PREFIX='output/webp/'

# --- WebP VTT backfill (backfill_webp_vtt.py) ---
# Run: python vtt-worker/backfill_webp_vtt.py --dry-run
# Uses MONGO_URI + GCS_BUCKET/GCS_PREFIX above (note: NOT VTT_GCS_BUCKET).
# export WEBP_QUALITY='65'              # 0-100 (default: 65)
# export THUMB_INTERVAL_SEC='3.0'       # seconds between thumbnails (default: 3.0)
# export VTT_BACKFILL_WORKERS='2'       # parallel workers (default: 2)
