# Local-only deploy secrets — DO NOT COMMIT
#
# 1. Copy this file to .env.deploy (gitignored):
#    cp deploy.env.example .env.deploy
# 2. Set MONGO_URI to your Atlas connection string (use a NEW password if the old one leaked).
# 3. Optional: set GCP_CREDENTIALS_SECRET_ARN to your Secrets Manager secret ARN (plain string).
#    If set, ./deploy.sh passes it to Terraform as gcp_credentials_secret_arn and skips creating a new GCP key.
# 4. Run: ./deploy.sh

MONGO_URI='mongodb+srv://USER:PASSWORD@cluster.mongodb.net/master?retryWrites=true&w=majority'
# export GCP_CREDENTIALS_SECRET_ARN='arn:aws:secretsmanager:REGION:ACCOUNT:secret:name-SUFFIX'
