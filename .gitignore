# macOS
.DS_Store

# Node / Next.js (dependencies and build output — reinstall with npm install)
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Terraform — state files contain secrets (MONGO_URI etc.) in plaintext
aws-infra/terraform.tfstate
aws-infra/terraform.tfstate*.backup
aws-infra/tfplan
aws-infra/.terraform/
aws-infra/import_existing.sh

# Lambda layer build artifacts (rebuilt by `terraform apply`)
aws-infra/.pymongo-layer/
aws-infra/.pymongo-layer.zip
aws-infra/.gcp-layer/
aws-infra/.gcp-layer.zip
aws-infra/.ffmpeg-layer/
aws-infra/.ffmpeg-layer.zip
aws-infra/.terraform.lock.hcl

# Secrets — never commit
aws-infra/terraform.tfvars
.env.deploy
.env.local
*.pem
# GCP service account JSON keys (e.g. downloaded from IAM)
media-cdn-poc-*.json

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Backfill log files
webp_backfill_*.log